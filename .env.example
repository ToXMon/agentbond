# ============================================================
# AgentBond — Environment Variables
# Copy to .env and fill with real values
# NEVER commit .env — only .env.example
# ============================================================

# ---- Venice AI (required for agent risk assessment) ----
VENICE_API_KEY=your-venice-api-key-here

# ---- Backend ----
PORT=3001
DATA_DIR=./data

# ---- Next.js Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key-here
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_IGNORE_BUILD_ERROR=false
NEXT_PUBLIC_IPFS_BUILD=false

# ---- Vercel (auto-set by Vercel deployment) ----
# VERCEL_PROJECT_PRODUCTION_URL=
# PORT=
